#!/usr/bin/env bash
#SBASH_ARG_1="<version>"
#USAGE arg "<version>" help="The new version number (e.g. 0.2.2)"

set -e

NEW_VERSION="${usage_version?}"
OLD_VERSION=$(grep -m 1 '^version = ' Cargo.toml | cut -d '"' -f 2)

if [[ "$NEW_VERSION" == "$OLD_VERSION" ]]; then
    echo "Version is already $NEW_VERSION"
    exit 0
fi

echo "Bumping version: $OLD_VERSION -> $NEW_VERSION"

# Update Cargo.toml
sed -i "s/^version = \"$OLD_VERSION\"/version = \"$NEW_VERSION\"/" Cargo.toml

# Update README.md
sed -i "s/version-$OLD_VERSION-blue/version-$NEW_VERSION-blue/g" README.md

# Update Cargo.lock
cargo check >/dev/null 2>&1

echo "Successfully bumped version to $NEW_VERSION"
