#!/usr/bin/env bash
#USAGE arg "[increment]" var=#true help="The increment type (major, minor, bugfix) or a literal version" {
#USAGE  choices "bugfix" "minor" "major"
#USAGE }

set -e

INCREMENT="${usage_increment?}"
OLD_VERSION=$(grep -m 1 '^version = ' Cargo.toml | cut -d '"' -f 2)

# Parse old version
IFS='.' read -r MAJOR MINOR PATCH <<< "$OLD_VERSION"

if [[ "$INCREMENT" == "major" ]]; then
    NEW_VERSION="$((MAJOR + 1)).0.0"
elif [[ "$INCREMENT" == "minor" ]]; then
    NEW_VERSION="$MAJOR.$((MINOR + 1)).0"
elif [[ "$INCREMENT" == "bugfix" ]]; then
    NEW_VERSION="$MAJOR.$MINOR.$((PATCH + 1))"
elif [[ "$INCREMENT" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    NEW_VERSION="$INCREMENT"
else
    echo "Error: Invalid increment type '$INCREMENT'. Use 'major', 'minor', 'bugfix', or a literal version (e.g., 1.2.3)."
    exit 1
fi

if [[ "$NEW_VERSION" == "$OLD_VERSION" ]]; then
    echo "Version is already $NEW_VERSION"
    exit 0
fi

echo "Bumping version: $OLD_VERSION -> $NEW_VERSION"

# Update Cargo.toml
sed -i "s/^version = \"$OLD_VERSION\"/version = \"$NEW_VERSION\"/" Cargo.toml

# Update README.md
sed -i "s/version-$OLD_VERSION-blue/version-$NEW_VERSION-blue/g" README.md

# Update Cargo.lock
cargo check >/dev/null 2>&1

echo "Successfully bumped version to $NEW_VERSION"
