#!/bin/env bash
#USAGE flag "-p --profile <profile>" help="Build with the specified profile" default="dev" {
#USAGE   choices "dev" "release"
#USAGE }
#USAGE flag "-t --target <target>" help="The target to build" default="x86_64-unknown-linux-gnu" {
#USAGE   choices "aarch64-apple-darwin" "aarch64-linux-android" "aarch64-unknown-linux-gnu" "aarch64-unknown-linux-musl" "x86_64-unknown-linux-gnu" "x86_64-unknown-linux-musl"
#USAGE }

set -e

# Set build mode variable
BUILD_MODE="debug"
if [[ "${usage_profile?}" == "release" ]]; then
    BUILD_MODE="release"
fi

echo
echo "TARGET : ${usage_target?}"
echo "PROFILE: ${usage_profile?}"
echo

cargo build --profile "${usage_profile?}" --target "${usage_target?}"

echo "Building development container image..."
docker build -t dotsy-dev .

echo "Running development container..."
docker run --hostname="desktop" -it --rm -v "$(pwd)/target/${usage_target}/${BUILD_MODE}/dotsy:/usr/local/bin/dotsy:Z" dotsy-dev
