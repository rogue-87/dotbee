{
  "$schema": "https://raw.githubusercontent.com/EmmyLuaLs/emmylua-analyzer-rust/refs/heads/main/crates/emmylua_code_analysis/resources/schema.json",
  "diagnostics": {
    "globals": [
      "vim"
    ]
  },
  "runtime": {
    "version": "LuaJIT",
    "requirePattern": [
      "lua/?.lua",
      "lua/?/init.lua"
    ]
  },
  "workspace": {
    "enableReindex": false,
    "library": [
      "$VIMRUNTIME",
      "${3rd}/luv/library",
      "${3rd}/busted/library",
      "~/.local/share/nvim/lazy/blink.cmp/",
      "~/.local/share/nvim/lazy/cord.nvim/",
      "~/.local/share/nvim/lazy/gitsigns.nvim/",
      "~/.local/share/nvim/lazy/guard.nvim/",
      "~/.local/share/nvim/lazy/kanagawa.nvim/",
      "~/.local/share/nvim/lazy/lazy.nvim/",
      "~/.local/share/nvim/lazy/markdown-plus.nvim/",
      "~/.local/share/nvim/lazy/mini.icons/",
      "~/.local/share/nvim/lazy/nightfox.nvim/",
      "~/.local/share/nvim/lazy/noice.nvim/",
      "~/.local/share/nvim/lazy/nvim-dap-view/",
      "~/.local/share/nvim/lazy/nvim-dap/",
      "~/.local/share/nvim/lazy/nvim-treesitter/",
      "~/.local/share/nvim/lazy/snacks.nvim/",
      "~/.local/share/nvim/lazy/render-markdown.nvim/",
      "~/.local/share/nvim/lazy/which-key.nvim/"
    ]
  }
}
